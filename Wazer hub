-- دالة إرسال رسالة إلى الشات
local function sendChatMessage(message)
    local success, err = pcall(function()
        local replicatedStorage = game:GetService("ReplicatedStorage")
        local chatEvent = replicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
        if chatEvent then
            local sayMessage = chatEvent:FindFirstChild("SayMessageRequest")
            if sayMessage then
                sayMessage:FireServer(message, "All")
            end
        end
    end)
    
    if not success then
        pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("SayMessageRequest"):FireServer(message, "All")
        end)
    end
end

-- دالة إعادة spawn تلقائي
local function startRespawnMonitor()
    local player = game.Players.LocalPlayer
    
    local function respawn()
        task.wait(1.5)
        pcall(function()
            local respawnEvent = game:GetService("ReplicatedStorage"):FindFirstChild("Respawn")
            if respawnEvent then
                respawnEvent:FireServer()
            else
                game:GetService("Players").LocalPlayer.Character.Humanoid.Health = 0
                task.wait(1)
                local respawnBindable = game:GetService("ReplicatedStorage"):FindFirstChild("RespawnBindable")
                if respawnBindable then
                    respawnBindable:FireServer()
                end
            end
        end)
    end
    
    player.CharacterAdded:Connect(function(character)
        local humanoid = character:WaitForChild("Humanoid", 5)
        if humanoid then
            humanoid.Died:Connect(function()
                respawn()
            end)
        end
    end)
    
    if player.Character then
        local humanoid = player.Character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.Died:Connect(function()
                respawn()
            end)
        end
    end
end

