-- ======================= وظائف المضادات =======================
-- مضاد الموت
task.spawn(function()
    while true do
        if AntiDeathEnabled then
            local player = game.Players.LocalPlayer
            local char = player.Character
            if char and char:FindFirstChild("Humanoid") then
                local humanoid = char.Humanoid
                if humanoid.Health < 100 then
                    humanoid.Health = 100
                end
                humanoid.BreakJointsOnDeath = false
            end
        end
        task.wait(0.1)
    end
end)

-- مضاد الجلوس
task.spawn(function()
    while true do
        if AntiSitEnabled then
            local player = game.Players.LocalPlayer
            local char = player.Character
            if char and char:FindFirstChild("Humanoid") then
                if char.Humanoid.Sit then
                    char.Humanoid.Sit = false
                end
            end
        end
        task.wait(0.05)
    end
end)

-- مضاد الفلنق
task.spawn(function()
    while true do
        if AntiFlingEnabled then
            local player = game.Players.LocalPlayer
            local char = player.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    for _, v in pairs(hrp:GetChildren()) do
                        if v:IsA("BodyVelocity") or v:IsA("BodyAngularVelocity") then
                            v:Destroy()
                        end
                    end
                    if hrp.AssemblyLinearVelocity.Magnitude > 50 then
                        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)

-- مضاد البانج
task.spawn(function()
    while true do
        if AntiPunchEnabled then
            local player = game.Players.LocalPlayer
            local char = player.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    for _, v in pairs(hrp:GetChildren()) do
                        if v:IsA("BodyVelocity") and v.Velocity.Magnitude < 100 then
                            v:Destroy()
                        end
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)

-- مراقبة تغير الشخصية
game.Players.LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    if AntiDeathEnabled then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.BreakJointsOnDeath = false
            humanoid.Health = 100
        end
    end
end)

-- تحديث قوائم اللاعبين
local function UpdateDropdowns()
    local players = {}
    for _, plr in pairs(game.Players:GetPlayers()) do
        if plr ~= game.Players.LocalPlayer then
            table.insert(players, plr.Name)
        end
    end
    if #players == 0 then players = {"-- لا يوجد لاعبين --"} end
    if PunchDropdown then PunchDropdown:SetOptions(players) end
    if FlingDropdown then FlingDropdown:SetOptions(players) end
end

UpdateDropdowns()
game.Players.PlayerAdded:Connect(UpdateDropdowns)
game.Players.PlayerRemoving:Connect(UpdateDropdowns)
