-- دالة إرسال رسالة إلى الشات
local function sendChatMessage(message)
    pcall(function()
        local replicatedStorage = game:GetService("ReplicatedStorage")
        local chatEvent = replicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
        if chatEvent then
            local sayMessage = chatEvent:FindFirstChild("SayMessageRequest")
            if sayMessage then
                sayMessage:FireServer(message, "All")
            end
        end
    end)
end

-- نظام إعادة spawn تلقائي
local function startRespawnMonitor()
    local player = game.Players.LocalPlayer
    
    local function respawn()
        task.wait(1.5)
        pcall(function()
            local respawnEvent = game:GetService("ReplicatedStorage"):FindFirstChild("Respawn")
            if respawnEvent then
                respawnEvent:FireServer()
            end
        end)
    end
    
    player.CharacterAdded:Connect(function(character)
        local humanoid = character:WaitForChild("Humanoid", 5)
        if humanoid then
            humanoid.Died:Connect(function()
                respawn()
            end)
        end
    end)
    
    if player.Character and player.Character:FindFirstChild("Humanoid") then
        player.Character.Humanoid.Died:Connect(function()
            respawn()
        end)
    end
end

-- دالة تحديث قائمة اللاعبين
local function RefreshPlayerList(Dropdown)
    local players = {}
    for i, player in ipairs(game.Players:GetPlayers()) do
        if player ~= game.Players.LocalPlayer then
            table.insert(players, player.Name)
        end
    end
    if Dropdown then
        Dropdown:SetOptions(players)
    end
    return players
end

-- دالة تنفيذ بانج فيس (Face Bang)
local function BangFace(targetPlayer)
    if not targetPlayer or targetPlayer == "" then
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "JOO Hub - بانج",
            Text = "❌ الرجاء اختيار لاعب أولاً!",
            Duration = 2
        })
        return
    end
    
    pcall(function()
        -- محاولة تنفيذ البانج على الوجه
        local remote = game:GetService("ReplicatedStorage"):FindFirstChild("BangFace")
        if remote then
            remote:FireServer(targetPlayer)
        else
            -- محاولة remote آخر
            local altRemote = game:GetService("ReplicatedStorage"):FindFirstChild("FaceBang")
            if altRemote then
                altRemote:FireServer(targetPlayer)
            end
        end
        
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "JOO Hub - بانج",
            Text = "✅ تم تنفيذ بانج فيس على " .. targetPlayer,
            Duration = 2
        })
    end)
end

