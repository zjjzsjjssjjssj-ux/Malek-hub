-- ======================= قائمة تلوين الاسم =======================
local ColorTab = Window:CreateTab("🎨 تلوين الاسم")

local ColoringEnabled = false
local CurrentHue = 0
local ColorLoop = nil

ColorTab:CreateToggle({
    Name = "🌈 تشغيل تلوين الاسم والبايو 🌈",
    CurrentValue = false,
    Flag = "ColorToggle",
    Callback = function(Value)
        ColoringEnabled = Value
        if Value then
            ColorLoop = task.spawn(function()
                while ColoringEnabled do
                    local color = Color3.fromHSV(CurrentHue, 1, 1)
                    local player = game.Players.LocalPlayer
                    if player and player.Character and player.Character:FindFirstChild("Head") then
                        local head = player.Character.Head
                        if head:FindFirstChild("NameDisplay") then
                            local nd = head.NameDisplay
                            if nd:FindFirstChild("Name") then nd.Name.TextColor3 = color end
                            if nd:FindFirstChild("DisplayName") then nd.DisplayName.TextColor3 = color end
                            if nd:FindFirstChild("Bio") then nd.Bio.TextColor3 = color end
                        end
                    end
                    CurrentHue = CurrentHue + 0.02
                    if CurrentHue > 1 then CurrentHue = 0 end
                    task.wait(0.1)
                end
            end)
            Rayfield:Notify({ Title = "🎨", Content = "تم تشغيل التلوين", Duration = 1.5 })
        else
            if ColorLoop then task.cancel(ColorLoop) end
            -- إعادة اللون إلى الأبيض
            local player = game.Players.LocalPlayer
            if player and player.Character and player.Character:FindFirstChild("Head") then
                local head = player.Character.Head
                if head:FindFirstChild("NameDisplay") then
                    local nd = head.NameDisplay
                    local white = Color3.fromRGB(255, 255, 255)
                    if nd:FindFirstChild("Name") then nd.Name.TextColor3 = white end
                    if nd:FindFirstChild("DisplayName") then nd.DisplayName.TextColor3 = white end
                    if nd:FindFirstChild("Bio") then nd.Bio.TextColor3 = white end
                end
            end
            Rayfield:Notify({ Title = "🎨", Content = "تم إيقاف التلوين", Duration = 1.5 })
        end
    end,
})

