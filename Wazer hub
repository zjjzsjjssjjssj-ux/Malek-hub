-- دالة تحميل Rayfield Library
local function LoadRayfieldLibrary()
    local success, lib = pcall(function()
        return loadstring(game:HttpGet("https://raw.githubusercontent.com/shlexware/Rayfield/main/source.lua"))()
    end)
    
    if success and lib then
        Rayfield = lib
        print("✅ Rayfield Library loaded successfully!")
        return true
    else
        local success2, lib2 = pcall(function()
            return loadstring(game:HttpGet("https://sirius.menu/rayfield"))()
        end)
        if success2 and lib2 then
            Rayfield = lib2
            print("✅ Rayfield Library loaded from alternative source!")
            return true
        else
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "JOO Hub",
                Text = "❌ فشل تحميل Rayfield! تأكد من اتصالك بالإنترنت",
                Duration = 5
            })
            return false
        end
    end
end

-- دالة النسخ إلى الحافظة
local function copyToClipboard(text)
    local success = false
    if setclipboard then
        success = pcall(function() setclipboard(text) end)
    elseif toclipboard then
        success = pcall(function() toclipboard(text) end)
    elseif ClipboardAsync then
        success = pcall(function() ClipboardAsync(text) end)
    end
    
    if not success then
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "JOO Hub",
            Text = "📋 تم نسخ: " .. text,
            Duration = 2
        })
    else
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "JOO Hub",
            Text = "✅ تم النسخ إلى الحافظة: " .. text,
            Duration = 1.5
        })
    end
end

